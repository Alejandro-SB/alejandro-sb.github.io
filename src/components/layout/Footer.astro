---
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p class="copy">
      &copy; {year} Alejandro SB. Built with
      <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.
    </p>
    <div class="links">
      <a href="https://github.com/alejandro-sb" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
      <a href="https://linkedin.com/in/placeholder" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    transition: border-color var(--transition-slow);
  }

  .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .copy {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .copy a {
    color: var(--color-accent-1);
    font-weight: 500;
    transition: opacity var(--transition-base);
  }

  .copy a:hover {
    opacity: 0.8;
  }

  .links {
    display: flex;
    gap: 1.5rem;
  }

  .links a {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color var(--transition-base);
  }

  .links a:hover {
    color: var(--color-accent-1);
  }
</style>
