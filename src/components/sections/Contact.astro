---
import Icon from '../ui/Icon.astro';
import { site } from '../../data/site';

const contacts = [
  {
    label: 'GitHub',
    href: site.githubUrl,
    icon: 'github',
    description: 'See my code & open source work',
    external: true,
  },
  {
    label: 'LinkedIn',
    href: site.linkedinUrl,
    icon: 'linkedin',
    description: 'Connect professionally',
    external: true,
  },
  {
    label: 'Email',
    href: `mailto:${site.email}`,
    icon: 'mail',
    description: site.email,
    external: false,
  },
];
---

<section id="contact" class="section">
  <div class="container">
    <h2 class="section-title">Get in Touch</h2>
    <p class="section-subtitle">
      I'm always open to interesting conversations and new opportunities.
    </p>

    <div class="cards">
      {contacts.map(contact => (
        <a
          href={contact.href}
          class="card"
          target={contact.external ? '_blank' : undefined}
          rel={contact.external ? 'noopener noreferrer' : undefined}
          aria-label={contact.label}
        >
          <span class="icon-wrap">
            <Icon iconName={contact.icon} size={28} />
          </span>
          <div>
            <p class="label">{contact.label}</p>
            <p class="desc">{contact.description}</p>
          </div>
          <Icon iconName="arrow_right" size={18} class="arrow" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 600px;
  }

  .cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base),
      border-color var(--transition-base);
  }

  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateX(4px);
    border-color: var(--color-accent-1);
  }

  .icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-accent-1) 10%, transparent);
    color: var(--color-accent-1);
    border: 1px solid color-mix(in srgb, var(--color-accent-1) 20%, transparent);
    flex-shrink: 0;
  }

  .label {
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: 0.1rem;
  }

  .arrow {
    margin-left: auto;
    color: var(--color-text-muted);
    flex-shrink: 0;
    transition: transform var(--transition-base), color var(--transition-base);
  }

  .card:hover .arrow {
    transform: translateX(4px);
    color: var(--color-accent-1);
  }
</style>
