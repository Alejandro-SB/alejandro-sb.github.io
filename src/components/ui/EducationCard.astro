---
import type { EducationItem } from '../../data/types';

type Props = EducationItem;
const { degree, field, institution, institutionUrl, startYear, endYear, gpa, highlights } = Astro.props;
---

<div class="card">
  <div class="card-top">
    <div class="icon-wrap" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
      </svg>
    </div>
    <div>
      <h3 class="degree">{degree}</h3>
      <p class="field">{field}</p>
    </div>
  </div>

  <p class="institution">
    {institutionUrl
      ? <a href={institutionUrl} target="_blank" rel="noopener noreferrer">{institution}</a>
      : institution
    }
  </p>

  <div class="meta">
    <span class="years">{startYear} – {endYear}</span>
    {gpa && <span class="gpa">GPA: {gpa}</span>}
  </div>

  {highlights && highlights.length > 0 && (
    <ul class="highlights">
      {highlights.map(h => <li>{h}</li>)}
    </ul>
  )}
</div>

<style>
  .card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: var(--color-accent-gradient);
  }

  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-accent-1) 10%, transparent);
    color: var(--color-accent-1);
    border: 1px solid color-mix(in srgb, var(--color-accent-1) 20%, transparent);
    flex-shrink: 0;
  }

  .degree {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
  }

  .field {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  .institution {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .institution a {
    color: var(--color-accent-1);
    transition: opacity var(--transition-base);
  }

  .institution a:hover {
    opacity: 0.8;
  }

  .meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .years, .gpa {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    background-color: var(--color-bg-subtle);
    padding: 0.2rem 0.7rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    list-style: none;
  }

  .highlights li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
  }

  .highlights li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent-3);
    font-size: 0.8em;
  }
</style>
