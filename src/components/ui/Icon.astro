  git: `<circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/><path d="M12 7v5l-5 5M12 12l5 5"/>`,
  docker: `<path d="M22 12.5c-.4-2.2-2-4-4.2-4.7C17.5 5.7 15.5 4 13 4c-1.7 0-3.3.8-4.4 2.1C5.8 6.4 4 8.5 4 11c0 3.3 2.7 6 6 6h9c1.7 0 3-1.3 3-3 0-.2 0-.3 0-.5z"/><line x1="8" y1="11" x2="8" y2="11.01"/><line x1="12" y1="11" x2="12" y2="11.01"/><line x1="16" y1="11" x2="16" y2="11.01"/>`,
