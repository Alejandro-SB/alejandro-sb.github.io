---
import TagBadge from './TagBadge.astro';
import Icon from './Icon.astro';
import type { Project } from '../../data/types';

type Props = Project;
const { title, description, tags, githubUrl, demoUrl, featured } = Astro.props;
---

<article class={`card ${featured ? 'card--featured' : ''}`}>
  <!-- Top accent bar -->
  <div class="accent-bar" aria-hidden="true"></div>

  <div class="card-body">
    <div class="card-header">
      <h3 class="title">{title}</h3>
      <div class="links">
        {githubUrl && (
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" aria-label={`GitHub: ${title}`}>
            <Icon name="github" size={18} />
          </a>
        )}
        {demoUrl && (
          <a href={demoUrl} target="_blank" rel="noopener noreferrer" aria-label={`Live demo: ${title}`}>
            <Icon name="external-link" size={18} />
          </a>
        )}
      </div>
    </div>

    <p class="description">{description}</p>

    <div class="tags">
      {tags.map(tag => <TagBadge label={tag} />)}
    </div>
  </div>
</article>

<style>
  .card {
    background-color: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base),
      border-color var(--transition-base);
  }

  .card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--color-accent-1) 40%, transparent);
  }

  .accent-bar {
    height: 4px;
    background: var(--color-accent-gradient);
  }

  .card--featured .accent-bar {
    height: 5px;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.3;
  }

  .links {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius-md);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    transition: color var(--transition-base), border-color var(--transition-base);
  }

  .links a:hover {
    color: var(--color-accent-1);
    border-color: var(--color-accent-1);
  }

  .description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }
</style>
