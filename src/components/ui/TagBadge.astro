---
interface Props {
  label: string;
  variant?: 'default' | 'accent';
}

const { label, variant = 'default' } = Astro.props;
---

<span class={`tag tag--${variant}`}>{label}</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.65rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .tag--default {
    background-color: var(--color-bg-subtle);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .tag--accent {
    background-color: color-mix(in srgb, var(--color-accent-1) 12%, transparent);
    color: var(--color-accent-1);
    border: 1px solid color-mix(in srgb, var(--color-accent-1) 25%, transparent);
  }
</style>
