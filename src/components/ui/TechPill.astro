---
interface Props {
  tech: string;
}

const { tech } = Astro.props;

const techImages: Record<string, string> = {
  "C#": "/csharp.svg",
  "F#": "/fsharp.svg",
  jQuery: "/jQuery.svg",
  KnockoutJS: "/Knockout.svg",
  React: "/react.svg",
  Vue: "/vue.svg",
  Azure: "/azure.svg",
  AWS: "/aws.svg",
  Rust: "/rust.svg",
  Elixir: "/Elixir.svg",
  Docker: "/docker.svg",
  SQL: "/sql.svg",
  ".NET": "/dotnet.svg",
  TypeScript: "/typescript.svg",
  JavaScript: "/javascript.svg",
};

const image = techImages[tech];
---

<span class="tech-pill" title={tech}>
  {image
    ? <img src={image} alt={tech} class="tech-icon" />
    : <span class="tech-name">{tech}</span>
  }
</span>

<style>
  .tech-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.6rem;
    border-radius: var(--radius-full);
    background-color: color-mix(in srgb, var(--color-accent-1) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent-1) 20%, transparent);
    height: 3rem;
  }

  .tech-icon {
    width: auto;
    height: 2rem;
    object-fit: contain;
  }

  .tech-name {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
  }
</style>
